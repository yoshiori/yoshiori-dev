---
interface Props {
  num: string;
  title: string;
}

const { num, title } = Astro.props;
---

<div class="flex items-baseline gap-5 mb-12">
  <span class="font-mono text-[11px] text-accent tracking-[0.15em]">{num}</span>
  <h2 class="font-display text-4xl tracking-wider text-text">{title}</h2>
</div>
