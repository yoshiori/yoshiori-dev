---
interface Role {
  title: string;
  bullets: string[];
}

interface Props {
  company: string;
  period: string;
  roles: Role[];
  skills?: string[];
  leadership?: string[];
}

const { company, period, roles, skills = [], leadership = [] } = Astro.props;
---

<div class="border-t border-border py-7 first:border-t-0">
  <div class="grid grid-cols-1 gap-2 sm:grid-cols-[180px_1fr] sm:gap-6">
    <div class="flex items-baseline gap-3 pt-0.5 sm:block">
      <div class="font-mono text-[11px] tracking-wider text-muted mb-1.5">{period}</div>
      <div class="text-xs font-medium text-accent">{company}</div>
    </div>
    <div class="flex flex-col gap-4">
      {roles.map(role => (
        <div>
          <div class="text-[15px] font-medium text-text mb-2">{role.title}</div>
          <ul class="list-none p-0">
            {role.bullets.map(b => (
              <li class="relative pl-4 py-0.5 text-[13px] text-subtle before:content-['—'] before:absolute before:left-0 before:text-border">{b}</li>
            ))}
          </ul>
        </div>
      ))}
      {(skills.length > 0 || leadership.length > 0) && (
        <div class="flex flex-wrap gap-1.5 pt-1">
          {skills.map(s => (
            <span class="font-mono text-[10px] text-muted border border-border px-2 py-0.5 tracking-wider">{s}</span>
          ))}
          {leadership.map(s => (
            <span class="font-mono text-[10px] text-accent/70 border border-accent/30 px-2 py-0.5 tracking-wider">{s}</span>
          ))}
        </div>
      )}
    </div>
  </div>
</div>
