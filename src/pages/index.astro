---
import '../styles/global.css';
import site from '../content/site.json';
import talks from '../content/talks.json';
import awards from '../content/awards.json';
import ExperienceItem from '../components/ExperienceItem.astro';
import TalkCard from '../components/TalkCard.astro';
import SectionHeader from '../components/SectionHeader.astro';

const experience = [
  {
    company: 'CloudBees Inc.',
    period: 'Jul 2024 – Present',
    roles: [
      {
        title: 'Engineering Director',
        bullets: [
          'Leading global engineering teams across India, Sri Lanka, Australia, and more',
          'Spearheaded CloudBees Smart Tests — InfoWorld AI Impact Awards winner',
          'Achieved 80% reduction in test execution time through product strategy',
        ],
      },
    ],
  },
  {
    company: 'Launchable Inc.',
    period: 'May 2020 – Aug 2024',
    roles: [
      {
        title: 'Principal Software Engineer',
        bullets: [
          'Joined Silicon Valley startup from 0→1 stage',
          'Core team member of "CloudBees Smart Tests" following acquisition',
          'Daily collaboration with global teams across 5+ countries in English',
        ],
      },
    ],
  },
  {
    company: 'Cookpad Japan',
    period: 'Nov 2012 – May 2020',
    roles: [
      {
        title: 'Head of CTO Office',
        bullets: [
          'Drove cross-cutting initiatives for all engineers — hackathons, workplace reforms, and development culture',
        ],
      },
      {
        title: 'Head of Tech Department / Engineering General Manager',
        bullets: [
          'Managed the shared platform engineering division serving all product teams',
        ],
      },
      {
        title: 'Head of HR',
        bullets: [
          'Led all HR functions including recruiting, performance reviews, and compensation',
          'Established hiring standards: "never lower team average"',
        ],
      },
      {
        title: 'Head of Recipe Posting',
        bullets: [
          'Managed the recipe posting service development team as department head',
        ],
      },
      {
        title: 'Software Engineer',
        bullets: [
          'Recipe posting platform development and led microservices migration',
          'Built company-wide video streaming infrastructure',
        ],
      },
    ],
  },
  {
    company: 'DWANGO Co., Ltd.',
    period: 'Mar 2009 – Oct 2012',
    roles: [
      {
        title: 'Engineer / System Leader',
        bullets: [
          'Built internal mobile revenue and expense aggregation system',
          'Developed Niconico Seiga (e-book platform)',
        ],
      },
    ],
  },
  {
    company: 'Growth Xpartners Inc.',
    period: 'Feb 2008 – Mar 2009',
    roles: [
      {
        title: 'Software Engineer',
        bullets: [
          'Performance tuning for municipal regional services',
          'Developed in-store visualization service',
        ],
      },
    ],
  },
  {
    company: 'BrainPad Inc.',
    period: 'Feb 2006 – Feb 2008',
    roles: [
      {
        title: 'Software Engineer',
        bullets: [
          'Developed recommendation engine product "Rtoaster"',
        ],
      },
    ],
  },
  {
    company: 'KBMJ, Inc.',
    period: 'Dec 2003 – Jan 2006',
    roles: [
      {
        title: 'Web Engineer',
        bullets: [
          'Built blog/RSS Japanese keyword tagging application',
          'Developed job-hunting support site using Google Maps API and Ajax',
          'Web application development for job listing platforms',
        ],
      },
    ],
  },
  {
    company: 'Zentech Technology Japan, Inc.',
    period: 'Aug 2001 – Dec 2003',
    roles: [
      {
        title: 'Software Engineer',
        bullets: [
          'DoCoMo mobile phone emulator development',
          'Built disaster prevention information system prototype for Hokkaido government',
        ],
      },
      {
        title: 'QA Engineer',
        bullets: [
          'DoCoMo mobile phone quality assurance',
          'Java VM quality assurance',
        ],
      },
    ],
  },
];

const skills = ['Java', 'Ruby', 'Python', 'Spring Boot', 'Ruby on Rails', 'AWS', 'Docker', 'Kubernetes', 'Bazel', 'CI/CD'];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{site.name}</title>
  <meta name="description" content={site.shortDescription} />
  <meta property="og:title" content={site.name} />
  <meta property="og:description" content={site.shortDescription} />
  <meta property="og:image" content={new URL("/og-image.png", Astro.url.origin).href} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans+JP:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="mx-auto max-w-[860px] px-6">

    <!-- Hero -->
    <header class="border-b border-border pb-20 pt-[100px]">
      <div class="mb-6 flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.2em] text-accent animate-[fadeUp_0.5s_ease_both]">
        {site.title} · {site.location}
        <span class="h-px flex-1 bg-accent opacity-30"></span>
      </div>
      <h1 class="font-display text-[clamp(72px,12vw,130px)] leading-[0.9] tracking-[0.02em] text-text mb-8 animate-[fadeUp_0.5s_0.1s_ease_both]">
        {site.firstName}<br /><span class="text-accent">{site.lastName}</span>
      </h1>
      <p class="max-w-[520px] text-sm text-soft mb-10 animate-[fadeUp_0.5s_0.2s_ease_both]">
        {site.description}
      </p>
      <nav class="flex flex-wrap gap-2 animate-[fadeUp_0.5s_0.3s_ease_both]">
        {site.links.map(l => (
          <a class="font-mono text-[11px] uppercase tracking-widest text-muted no-underline border border-border px-3.5 py-1.5 transition-all duration-200 hover:text-accent hover:border-accent hover:bg-accent/[0.04]" href={l.href} target="_blank" rel="noopener">{l.label}</a>
        ))}
        <a class="font-mono text-[11px] uppercase tracking-widest text-muted no-underline border border-border px-3.5 py-1.5 transition-all duration-200 hover:text-accent hover:border-accent hover:bg-accent/[0.04]" href={`mailto:${site.email}`}>Email</a>
      </nav>
    </header>

    <!-- Experience -->
    <section class="border-b border-border py-[72px]" id="experience">
      <SectionHeader num="01" title="Experience" />
      <div>
        {experience.map(exp => (
          <ExperienceItem company={exp.company} period={exp.period} roles={exp.roles} />
        ))}
      </div>
    </section>

    <!-- Skills -->
    <section class="border-b border-border py-[72px]" id="skills">
      <SectionHeader num="02" title="Skills" />
      <div class="flex flex-wrap gap-2">
        {skills.map(s => (
          <span class="font-mono text-xs text-muted border border-border px-3 py-1 tracking-wider transition-all duration-200 hover:text-text hover:border-border-hover">{s}</span>
        ))}
      </div>
    </section>

    <!-- Talks -->
    <section class="border-b border-border py-[72px]" id="talks">
      <SectionHeader num="03" title="Talks" />
      <div class="grid grid-cols-[repeat(auto-fill,minmax(220px,1fr))] gap-3">
        {talks.map(talk => (
          <TalkCard title={talk.title} url={talk.url} thumbnail={talk.thumbnail} date={talk.date} />
        ))}
      </div>
    </section>

    <!-- Recognition -->
    <section class="border-b border-border py-[72px]" id="recognition">
      <SectionHeader num="04" title="Recognition" />
      <div class="flex flex-col">
        {awards.map((award, i) => (
          <div class:list={["flex items-baseline gap-5 py-4", i > 0 && "border-t border-border"]}>
            <span class="font-mono text-[11px] text-accent min-w-[48px]">{award.year}</span>
            <span class="text-[13px] text-dim">{award.text}</span>
          </div>
        ))}
      </div>
    </section>

    <footer class="flex flex-col items-center gap-2 py-12 text-center sm:flex-row sm:justify-between sm:text-left">
      <span class="font-mono text-[11px] text-muted">© {site.name}</span>
      <a class="font-mono text-[11px] text-muted no-underline transition-colors duration-200 hover:text-accent" href={`mailto:${site.email}`}>{site.email}</a>
    </footer>

  </div>
</body>
</html>
