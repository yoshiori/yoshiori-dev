---
import '../styles/global.css';
import site from '../content/site.json';
import talks from '../content/talks.json';
import awards from '../content/awards.json';
import publications from '../content/publications.json';
import media from '../content/media.json';
import experience from '../content/experience.json';
import BackgroundImage from '../components/BackgroundImage.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import TalkMarquee from '../components/TalkMarquee.tsx';
import SectionHeader from '../components/SectionHeader.astro';
import { Icon } from 'astro-icon/components';

// Aggregate skills from experience data
function aggregate(key: 'skills' | 'leadership') {
  const count = new Map<string, number>();
  for (const exp of experience) {
    for (const s of exp[key] ?? []) {
      count.set(s, (count.get(s) ?? 0) + 1);
    }
  }
  return [...count.entries()].sort((a, b) => b[1] - a[1]).map(([name]) => name);
}
const skills = aggregate('skills');
const leadership = aggregate('leadership');
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{site.name}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="description" content={site.shortDescription} />
  <meta property="og:title" content={site.name} />
  <meta property="og:description" content={site.shortDescription} />
  <meta property="og:image" content={new URL("/og-image.png", Astro.url.origin).href} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans+JP:wght@300;400;500&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": site.name,
    "jobTitle": site.title,
    "url": site.siteUrl,
    "image": `${site.siteUrl}/og-image.png`,
    "email": site.email,
    "description": site.shortDescription,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Tokyo",
      "addressCountry": "JP"
    },
    "sameAs": site.links.map(l => l.href)
  })} />
</head>
<body>
  <div class="mx-auto max-w-[860px] px-6">

    <!-- Hero -->
    <header class="border-b border-border pb-20 pt-[100px]">
      <div class="mb-6 flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.2em] text-accent animate-[fadeUp_0.5s_ease_both]">
        {site.title} · {site.location}
        <span class="h-px flex-1 bg-accent opacity-30"></span>
      </div>
      <div class="relative overflow-hidden">
        <BackgroundImage src="/avatar.png" />
        <div class="relative">
          <h1 class="font-display text-[clamp(72px,12vw,130px)] leading-[0.9] tracking-[0.02em] text-text mb-8 animate-[fadeUp_0.5s_0.1s_ease_both]">
            {site.firstName}<br /><span class="text-accent">{site.lastName}</span>
          </h1>
          <p class="max-w-[520px] text-sm text-soft mb-10 animate-[fadeUp_0.5s_0.2s_ease_both]">
            {site.description}
          </p>
          <nav class="flex flex-wrap gap-2 animate-[fadeUp_0.5s_0.3s_ease_both]">
            {site.links.map(l => (
              <a class="inline-flex items-center gap-1.5 font-mono text-[11px] tracking-widest text-muted no-underline border border-border px-3.5 py-1.5 transition-all duration-200 hover:text-accent hover:border-accent hover:bg-accent/[0.04]" href={l.href} target="_blank" rel="noopener noreferrer">
                <Icon name={l.icon} class="size-3.5" />
                {l.label}
              </a>
            ))}
            <a class="inline-flex items-center gap-1.5 font-mono text-[11px] tracking-widest text-muted no-underline border border-border px-3.5 py-1.5 transition-all duration-200 hover:text-accent hover:border-accent hover:bg-accent/[0.04]" href={`mailto:${site.email}`}>
              <Icon name="lucide:mail" class="size-3.5" />
              Email
            </a>
          </nav>
        </div>
      </div>
    </header>

    <!-- Experience -->
    <section class="border-b border-border py-[72px]" id="experience">
      <SectionHeader num="01" title="Experience" />
      <div>
        {experience.map(exp => (
          <ExperienceItem company={exp.company} period={exp.period} roles={exp.roles} skills={exp.skills} leadership={exp.leadership} />
        ))}
      </div>
    </section>

    <!-- Skills -->
    <section class="border-b border-border py-[72px]" id="skills">
      <SectionHeader num="02" title="Skills" />
      <div class="mb-4">
        <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted mb-3">Technical</div>
        <div class="flex flex-wrap gap-2">
          {skills.map(name => (
            <span class="font-mono text-xs text-muted border border-border px-3 py-1 tracking-wider transition-all duration-200 hover:text-text hover:border-border-hover">{name}</span>
          ))}
        </div>
      </div>
      <div>
        <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted mb-3">Management</div>
        <div class="flex flex-wrap gap-2">
          {leadership.map(name => (
            <span class="font-mono text-xs text-accent/70 border border-accent/30 px-3 py-1 tracking-wider transition-all duration-200 hover:text-accent hover:border-accent">{name}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Publications -->
    <section class="border-b border-border py-[72px]" id="publications">
      <SectionHeader num="03" title="Publications" />
      <div class="relative overflow-hidden">
        <BackgroundImage src="/github-avatar.png" />
        <div class="relative flex flex-col">
          {publications.map((pub, i) => (
            <a href={pub.url} target="_blank" rel="noopener noreferrer" class:list={["flex items-baseline gap-5 py-4 no-underline transition-colors duration-200 hover:bg-accent/[0.04]", i > 0 && "border-t border-border"]}>
              <span class="font-mono text-[11px] text-accent min-w-[48px]">{pub.year}</span>
              <span class="flex flex-col gap-0.5">
                <span class="text-[13px] text-text">{pub.title}</span>
                <span class="text-[11px] text-muted">{pub.publisher} · {pub.role}</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Talks -->
    <section class="border-b border-border py-[72px]" id="talks">
      <SectionHeader num="04" title="Talks" />
      <TalkMarquee talks={talks} client:visible />
    </section>

    <!-- Media -->
    <section class="border-b border-border py-[72px]" id="media">
      <SectionHeader num="05" title="Media" />
      <div class="flex flex-col">
        {media.map((item, i) => (
          <a href={item.url} target="_blank" rel="noopener noreferrer" class:list={["flex items-baseline gap-5 py-4 no-underline transition-colors duration-200 hover:bg-accent/[0.04]", i > 0 && "border-t border-border"]}>
            <span class="font-mono text-[11px] text-accent min-w-[48px]">{item.year}</span>
            <span class="flex flex-col gap-0.5">
              <span class="text-[13px] text-text">{item.title}</span>
              <span class="text-[11px] text-muted">{item.publisher}</span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- Recognition -->
    <section class="border-b border-border py-[72px]" id="recognition">
      <SectionHeader num="06" title="Recognition" />
      <div class="flex flex-col">
        {awards.map((award, i) => (
          <div class:list={["flex items-baseline gap-5 py-4", i > 0 && "border-t border-border"]}>
            <span class="font-mono text-[11px] text-accent min-w-[48px]">{award.year}</span>
            <span class="text-[13px] text-dim">{award.text}</span>
          </div>
        ))}
      </div>
    </section>

    <footer class="flex flex-col items-center gap-2 py-12 text-center sm:flex-row sm:justify-between sm:text-left">
      <span class="font-mono text-[11px] text-muted">© {site.name}</span>
      <a class="font-mono text-[11px] text-muted no-underline transition-colors duration-200 hover:text-accent" href={`mailto:${site.email}`}>{site.email}</a>
    </footer>

  </div>
</body>
</html>
